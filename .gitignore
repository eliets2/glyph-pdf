# Build artifacts
build/
*.o
*.obj
*.a
*.lib
*.dll
*.exe
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
*.ninja

# Test artifacts
smoke_test_*.pdf
smoke_test_*.docx
smoke_test_*.xlsx

# Autosave
autosave/

# Qt Creator
*.pro.user
*.qmlproject.user

# Obsidian vault config
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/plugins/
.obsidian/cache
.obsidian/

# Claude agent planning docs (session-local)
.agents/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Vendor import libraries (MinGW .dll.a stubs) — small and needed for linking
!third_party/**/*.dll.a
!third_party/**/*.lib

# Vendor SDKs (large binaries — obtain via CMake FetchContent or vcpkg)
onnxruntime-win-x64-*/
onnxruntime-osx-*/
onnxruntime-linux-*/

# ML model weights (binary, managed separately)
models/
# Track provenance documentation within models/ despite the above exclusion
!models/**/PROVENANCE.md
!models/**/STATUS.md

# Test output logs
test_out*.log
test_err*.log
test_output.txt
test_results.txt
test_stderr.txt
test_stdout.txt
out.txt
out_test.txt
trc_out.txt
tsv_out.txt
# CTest output dir (capital T — exclude only the root-level CTest artefacts)
/Testing/

# Agent scratch files (Pattern 3 in agent-execution-anti-patterns)
scratch_*
scratch/
*.tmp.md
script*.ps1
tmp_*.pdf
tmp_signed_*.pdf

# Autosave artifacts (from AutosaveManager M1)
*.autosave.pdf
*.autosave.pdf.tmp

# Signing fixtures: test-only keys/certs are intentionally committed (test infrastructure).
# They are NOT production keys. R2-8 will purge the old compromised a6ea6aa history.
# Do NOT add exclusion patterns here — these files must be tracked.
# If you regenerate, re-commit: git add tests/fixtures/signing/ && git commit

# Vendored PoDoFo 1.1.0 build artifact (install tree is tracked separately)
third_party/podofo_build/

# Graphify
graphify-out/*
!graphify-out/graph.json
!graphify-out/graph.html
!graphify-out/GRAPH_REPORT.md
!graphify-out/manifest.json



# generated audit report (regen: python docs/audit/_gen_pdf.py)
docs/audit/*.pdf
docs/audit/_*.log
