.obsidian/workspace-mobile.json
.obsidian/plugins/
.obsidian/cache

# OS
.DS_Store
Thumbs.db
desktop.ini

# Vendor import libraries (MinGW .dll.a stubs) — small and needed for linking
!third_party/**/*.dll.a
!third_party/**/*.lib

# Vendor SDKs (large binaries — obtain via CMake FetchContent or vcpkg)
onnxruntime-win-x64-*/
onnxruntime-osx-*/
onnxruntime-linux-*/

# ML model weights (binary, managed separately)
models/

# Test output logs
test_out*.log
test_err*.log
test_output.txt
test_results.txt
Testing/

# Agent scratch files (Pattern 3 in agent-execution-anti-patterns)
scratch_*
scratch/
*.tmp.md
script*.ps1
tmp_*.pdf
tmp_signed_*.pdf

# Autosave artifacts (from AutosaveManager M1)
*.autosave.pdf
*.autosave.pdf.tmp

# Signing fixtures generated binaries (script regenerates)
tests/fixtures/signing/*.p12
tests/fixtures/signing/*.key
tests/fixtures/signing/*.crt
tests/fixtures/signing/*.csr
tests/fixtures/signing/*.srl

# Vendored PoDoFo 1.1.0 build artifact (install tree is tracked separately)
