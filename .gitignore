# Build artifacts
build/
*.o
*.obj
*.a
*.lib
*.dll
*.exe
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
*.ninja

# Test artifacts
smoke_test_*.pdf
smoke_test_*.docx
smoke_test_*.xlsx

# Autosave
autosave/

# Qt Creator
*.pro.user
*.qmlproject.user

# Obsidian vault config
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/plugins/
.obsidian/cache
.obsidian/

# Claude agent planning docs (session-local)
.agents/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Vendor import libraries (MinGW .dll.a stubs) — small and needed for linking
!third_party/**/*.dll.a
!third_party/**/*.lib

# Vendor SDKs (large binaries — obtain via CMake FetchContent or vcpkg)
onnxruntime-win-x64-*/
onnxruntime-osx-*/
onnxruntime-linux-*/

# ML model weights (binary, managed separately)
models/
# Track provenance documentation within models/ despite the above exclusion
!models/**/PROVENANCE.md
!models/**/STATUS.md

# Test output logs
test_out*.log
test_err*.log
test_output.txt
test_results.txt
test_stderr.txt
test_stdout.txt
out.txt
out_test.txt
trc_out.txt
tsv_out.txt
# CTest output dir (capital T — exclude only the root-level CTest artefacts)
/Testing/

# Agent scratch files (Pattern 3 in agent-execution-anti-patterns)
scratch_*
scratch/
*.tmp.md
script*.ps1
tmp_*.pdf
tmp_signed_*.pdf

# Autosave artifacts (from AutosaveManager M1)
*.autosave.pdf
*.autosave.pdf.tmp

# Signing fixtures: test-only keys/certs are intentionally committed (test infrastructure).
# They are NOT production keys. R2-8 will purge the old compromised a6ea6aa history.
# Do NOT add exclusion patterns here — these files must be tracked.
# If you regenerate, re-commit: git add tests/fixtures/signing/ && git commit

# Vendored PoDoFo 1.1.0 build artifact (install tree is tracked separately)
third_party/podofo_build/

# Optional bundled veraPDF CLI tree (~150 MB incl. its JRE) — staged into the
# installer by deploy.ps1 when present, never committed to source.
third_party/verapdf/
# Scratch dir used to download/assemble the veraPDF bundle (regenerable).
_verapdf_build/

# Built installer artifacts — large binaries, regenerated by packaging/build-msi.ps1.
# The MSI ships as a GitHub Release asset, NOT in git history.
dist/
deploy/

# Dead vcpkg artifacts — project migrated to MSYS2 ucrt64 (vcpkg no longer used).
vcpkg_installed/
vcpkg.json

# Internal working notes (AI session context, Obsidian vault, session planning) —
# kept locally for the team, not part of the public source distribution.
.context/
memory/
SESSION_BRIEF_NEXT.md
SESSION_PROMPTS_V2.md
docs/audit/REMEDIATION-SESSION-PROMPTS.md
docs/planning/NEXT-SESSION-HAND-OFF.md

# Graphify dev tooling output (regenerated on demand).
graphify-out/

# Graphify dev output is fully ignored (see consolidated rule above).



# generated audit report
docs/audit/*.pdf
docs/audit/_*.log

# AI-session working material — kept locally per session, never committed.
# (Removed from tracking 2026-06-13: build walkthroughs + raw multi-agent audit
#  dumps were internal session logs, not part of the public source distribution.)
docs/**/walkthroughs/
docs/audit/_workstreams/
docs/audit/round2/
docs/planning/*-CATCHUP-PROMPT.md
docs/planning/*-PROMPTS.md
