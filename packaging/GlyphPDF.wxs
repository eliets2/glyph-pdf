<?xml version="1.0" encoding="UTF-8"?>
<!--
  GlyphPDF — WiX v4 MSI installer (Session 17 D2)

  Installs to Program Files, creates Start Menu + Desktop shortcuts,
  registers .pdf file association as OpenWith option (NOT hijacking default),
  supports upgrade/uninstall via MajorUpgrade.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Package
    Name="GlyphPDF"
    Manufacturer="Glyph"
    Version="1.0.0.0"
    UpgradeCode="fb1fbe00-e1af-449c-8a58-2d2e308b9127"
    Scope="perMachine"
    Language="1033"
    Compressed="yes">

    <MajorUpgrade
      DowngradeErrorMessage="A newer version of [ProductName] is already installed."
      Schedule="afterInstallInitialize" />

    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <Icon Id="GlyphPDFIcon" SourceFile="$(var.DeployDir)\glyphpdf.ico" />
    <Property Id="ARPPRODUCTICON" Value="GlyphPDFIcon" />
    <Property Id="ARPHELPLINK" Value="https://glyphpdf.com" />

    <!-- ── Feature tree ──────────────────────────────────────────── -->
    <Feature Id="Core" Title="GlyphPDF Application" Level="1" AllowAbsent="no">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentGroupRef Id="Shortcuts" />
    </Feature>

    <Feature Id="FileAssoc" Title="PDF File Association" Level="1" AllowAbsent="yes">
      <ComponentRef Id="PdfFileAssociation" />
    </Feature>

    <!-- ── Directory structure ────────────────────────────────────── -->
    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="GlyphPDF" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="GlyphPDF" />
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder" />

    <!-- ── App files (harvested from deploy/) ────────────────────── -->
    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Files Include="$(var.DeployDir)\**" />
    </ComponentGroup>

    <!-- ── Shortcuts ──────────────────────────────────────────────── -->
    <ComponentGroup Id="Shortcuts">
      <Component Id="StartMenuShortcut" Directory="ApplicationProgramsFolder" Guid="a7c91e33-4b8f-4d3a-b0e1-f8a2c3d4e5f6">
        <Shortcut Id="StartMenuSC"
                  Name="GlyphPDF"
                  Target="[INSTALLFOLDER]GlyphPDF.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="GlyphPDFIcon" />
        <RemoveFolder Id="RemoveStartMenuDir" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\Glyph\GlyphPDF" Name="StartMenu" Type="integer" Value="1" KeyPath="yes" />
      </Component>

      <Component Id="DesktopShortcut" Directory="DesktopFolder" Guid="b8d02f44-5c9e-4e4b-c1f2-09b3d4e5f6a7">
        <Shortcut Id="DesktopSC"
                  Name="GlyphPDF"
                  Target="[INSTALLFOLDER]GlyphPDF.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="GlyphPDFIcon" />
        <RegistryValue Root="HKCU" Key="Software\Glyph\GlyphPDF" Name="Desktop" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- ── PDF file association (OpenWith, NOT hijacking default) ── -->
    <Component Id="PdfFileAssociation" Directory="INSTALLFOLDER" Guid="c9e13a55-6da0-4f5c-d2a3-1ac4e5f6b7c8">
      <RegistryValue Root="HKLM"
                     Key="SOFTWARE\Classes\.pdf\OpenWithProgids"
                     Name="GlyphPDF.Document"
                     Type="string"
                     Value=""
                     KeyPath="yes" />
      <RegistryValue Root="HKLM"
                     Key="SOFTWARE\Classes\GlyphPDF.Document"
                     Type="string"
                     Value="PDF Document — GlyphPDF" />
      <RegistryValue Root="HKLM"
                     Key="SOFTWARE\Classes\GlyphPDF.Document\DefaultIcon"
                     Type="string"
                     Value="[INSTALLFOLDER]GlyphPDF.exe,0" />
      <RegistryValue Root="HKLM"
                     Key="SOFTWARE\Classes\GlyphPDF.Document\shell\open\command"
                     Type="string"
                     Value="&quot;[INSTALLFOLDER]GlyphPDF.exe&quot; &quot;%1&quot;" />
    </Component>

  </Package>
</Wix>
