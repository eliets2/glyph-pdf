<?xml version="1.0" encoding="UTF-8"?>
<!--
  GlyphPDF — WiX v4/v5 MSI installer (Session 17 D2; R4 packaging pass)

  Installs to Program Files, creates Start Menu + Desktop shortcuts,
  registers .pdf file association as OpenWith option (NOT hijacking default),
  supports upgrade/uninstall via MajorUpgrade.

  R4: WixUI_InstallDir dialog set (license agreement + install location),
  full payload now includes ONNX models (ROVER ensemble + layout detection)
  and bundled tessdata so the installed app needs zero network access.

  Build:  wix build -src GlyphPDF.wxs -d DeployDir=..\deploy
               -ext WixToolset.UI.wixext -arch x64 -out GlyphPDF-1.0.1-x64.msi
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package
    Name="GlyphPDF"
    Manufacturer="Glyph"
    Version="1.0.1.0"
    UpgradeCode="fb1fbe00-e1af-449c-8a58-2d2e308b9127"
    ProductCode="83AD3854-CF43-4F27-B34D-CBB42B5624AB"
    Scope="perMachine"
    Language="1033"
    Compressed="yes">

    <!-- ProductCode is PINNED per release so the shipped MSI and the winget
         manifest (packaging/winget) always agree and rebuilds are reproducible.
         A NEW ProductCode is generated for every released version (MSI major-
         upgrade semantics require it) while keeping UpgradeCode constant so
         MajorUpgrade replaces the prior install. History:
           v1.0.0  5BA17AB1-F3AC-4A62-B02E-27FC9B77F691
           v1.0.1  83AD3854-CF43-4F27-B34D-CBB42B5624AB -->
    <MajorUpgrade
      DowngradeErrorMessage="A newer version of [ProductName] is already installed."
      Schedule="afterInstallInitialize" />

    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <Icon Id="GlyphPDFIcon" SourceFile="$(var.DeployDir)\glyphpdf.ico" />
    <Property Id="ARPPRODUCTICON" Value="GlyphPDFIcon" />
    <Property Id="ARPHELPLINK" Value="https://github.com/eliets2/glyph-pdf" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/eliets2/glyph-pdf" />
    <Property Id="ARPCOMMENTS" Value="Privacy-first PDF workstation — no telemetry, no cloud, documents stay on your machine." />

    <!-- ── Installer UI: license agreement + install-dir chooser ──── -->
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

    <!-- ── Feature tree ──────────────────────────────────────────── -->
    <Feature Id="Core" Title="GlyphPDF Application" Level="1" AllowAbsent="no">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentGroupRef Id="Shortcuts" />
    </Feature>

    <Feature Id="FileAssoc" Title="PDF File Association" Level="1" AllowAbsent="yes">
      <ComponentRef Id="PdfFileAssociation" />
    </Feature>

    <!-- ── Directory structure ────────────────────────────────────── -->
    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="GlyphPDF" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="GlyphPDF" />
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder" />

    <!-- ── App files (harvested from deploy/) ────────────────────── -->
    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Files Include="$(var.DeployDir)\**" />
    </ComponentGroup>

    <!-- ── Shortcuts ──────────────────────────────────────────────── -->
    <ComponentGroup Id="Shortcuts">
      <Component Id="StartMenuShortcut" Directory="ApplicationProgramsFolder" Guid="a7c91e33-4b8f-4d3a-b0e1-f8a2c3d4e5f6">
        <Shortcut Id="StartMenuSC"
                  Name="GlyphPDF"
                  Target="[INSTALLFOLDER]GlyphPDF.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="GlyphPDFIcon" />
        <RemoveFolder Id="RemoveStartMenuDir" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\Glyph\GlyphPDF" Name="StartMenu" Type="integer" Value="1" KeyPath="yes" />
      </Component>

      <Component Id="DesktopShortcut" Directory="DesktopFolder" Guid="b8d02f44-5c9e-4e4b-c1f2-09b3d4e5f6a7">
        <Shortcut Id="DesktopSC"
                  Name="GlyphPDF"
                  Target="[INSTALLFOLDER]GlyphPDF.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="GlyphPDFIcon" />
        <RegistryValue Root="HKCU" Key="Software\Glyph\GlyphPDF" Name="Desktop" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- ── PDF file association (OpenWith, NOT hijacking default) ── -->
    <Component Id="PdfFileAssociation" Directory="INSTALLFOLDER" Guid="c9e13a55-6da0-4f5c-d2a3-1ac4e5f6b7c8">
      <RegistryValue Root="HKLM"
                     Key="SOFTWARE\Classes\.pdf\OpenWithProgids"
                     Name="GlyphPDF.Document"
                     Type="string"
                     Value=""
                     KeyPath="yes" />
      <RegistryValue Root="HKLM"
                     Key="SOFTWARE\Classes\GlyphPDF.Document"
                     Type="string"
                     Value="PDF Document — GlyphPDF" />
      <RegistryValue Root="HKLM"
                     Key="SOFTWARE\Classes\GlyphPDF.Document\DefaultIcon"
                     Type="string"
                     Value="[INSTALLFOLDER]GlyphPDF.exe,0" />
      <RegistryValue Root="HKLM"
                     Key="SOFTWARE\Classes\GlyphPDF.Document\shell\open\command"
                     Type="string"
                     Value="&quot;[INSTALLFOLDER]GlyphPDF.exe&quot; &quot;%1&quot;" />
    </Component>

  </Package>
</Wix>
